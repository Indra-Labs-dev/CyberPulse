APP_NAME=CyberPulse
ENVIRONMENT=development
DEBUG=true

# MySQL (async, used by the app)
DATABASE_URL=mysql+aiomysql://cyberpulse:cyberpulse@localhost:3306/cyberpulse

# MySQL (sync, used by Alembic migrations)
DATABASE_URL_SYNC=mysql+pymysql://cyberpulse:cyberpulse@localhost:3306/cyberpulse

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Scraping
SCRAPING_ENABLED=true
SCRAPING_INTERVAL_MINUTES=15
SCRAPING_USER_AGENT=CyberPulseBot/1.0 (+https://indralabs.example)

# CVE Sync
CVE_SYNC_ENABLED=true
CVE_SYNC_INTERVAL_MINUTES=60

# Reports storage
REPORTS_DIR=./storage/reports

# OSINT module (optional — leave blank to use placeholder results)
HIBP_API_KEY=
SHODAN_API_KEY=
GITHUB_TOKEN=
